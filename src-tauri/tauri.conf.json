{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SchemaForge",
  "version": "0.1.1",
  "identifier": "com.spencerchang.schemaforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run generator:build && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SchemaForge",
        "width": 1080,
        "height": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": {
      "../backend/target/schema-forge-generator-0.1.0-SNAPSHOT.jar": "schema-forge-generator.jar"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
