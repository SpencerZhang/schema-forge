{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SchemaForge",
  "version": "0.2.0",
  "identifier": "com.spencerchang.schemaforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SchemaForge - 数据库字典生成器",
        "width": 1280,
        "minWidth": 1180,
        "height": 860,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
